# --- Instagram (Facebook Graph API) ---
INSTAGRAM_ACCESS_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
INSTAGRAM_USER_ID=your-user-id
INSTAGRAM_ACCOUNT_ID=XXXXXXXXXXXXXXXXXX
FACEBOOK_PAGE_ID=XXXXXXXXXXXXXXXXXX

# --- TikTok ---
TIKTOK_ACCESS_TOKEN=your-tiktok-token
TIKTOK_CLIENT_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TIKTOK_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Armazenamento local (dentro do container Docker) ---
OUTPUT_DIR=/data/output
TEMP_DIR=/data/temp
ASSETS_DIR=/data/assets
SCRIPTS_DIR=/data/scripts

# --- FFmpeg ---
FFMPEG_PATH=ffmpeg

# --- Configuração de Lote ---
VIDEOS_PER_RUN=1
# Cron: 4x ao dia (8h, 12h, 16h, 20h) = "0 8,12,16,20 * * *" | diário às 6h = "0 6 * * *"
SCHEDULE_CRON=0 8,12,16,20 * * *
AUTO_PUBLISH=false

# --- n8n ---
N8N_WEBHOOK_URL=https://your-n8n.com/webhook
N8N_BASE_URL=https://your-n8n-instance.easypanel.host/
N8N_WEBHOOK_SECRET=your-n8n-api-key-jwt-here

# --- Notificações Telegram (opcional) ---
TELEGRAM_BOT_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TELEGRAM_CHAT_ID=XXXXXXXXXXXXXXXXXX
