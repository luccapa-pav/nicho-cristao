# --- YouTube ---
YOUTUBE_API_KEY=your-youtube-api-key
YOUTUBE_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-XXXXXXXXXXXXXXXXXXXXXXXXX
YOUTUBE_REFRESH_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
