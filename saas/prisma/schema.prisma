// ============================================================
// SCHEMA - SaaS Cristão "Luz Divina"
// Stack: PostgreSQL + Prisma ORM
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// USUÁRIOS
// ─────────────────────────────────────────────
model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String?
  avatarUrl     String?
  bio           String?
  church        String?
  city          String?
  verse         String?
  ministry      String?
  plan          Plan     @default(FREE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relações
  streak        Streak?
  groupMember   GroupMember[]
  prayers       Prayer[]
  gratitudePosts GratitudePost[]
  reactions     Reaction[]
  devotionalLogs DevotionalLog[]
  sentInvites   GroupInvite[]  @relation("InviteSender")
  fcmTokens        FcmToken[]
  readingProgress  ReadingProgress[]
  journalEntries   JournalEntry[]
  memorizedVerses  MemorizedVerse[]
  notifications    Notification[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  emailVerified    DateTime?

  @@map("users")
}

enum Plan {
  FREE
  PREMIUM
  FAMILY
}

// ─────────────────────────────────────────────
// STREAK (OFENSIVA DIÁRIA)
// ─────────────────────────────────────────────
model Streak {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak  Int      @default(0)
  longestStreak  Int      @default(0)
  lastCheckIn    DateTime?
  totalDays      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("streaks")
}

// ─────────────────────────────────────────────
// DEVOCIONAIS (Cápsula de Áudio + Versículo)
// ─────────────────────────────────────────────
model Devotional {
  id          String   @id @default(cuid())
  date        DateTime @unique @db.Date
  title       String
  verse       String
  verseRef    String   // Ex: "João 3:16"
  audioUrl    String?
  audioDuration Int?   // segundos
  theme       String?
  publishedAt DateTime @default(now())

  logs        DevotionalLog[]

  @@map("devotionals")
}

model DevotionalLog {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  devotionalId String
  devotional   Devotional @relation(fields: [devotionalId], references: [id])
  listenedAt   DateTime   @default(now())
  completed    Boolean    @default(false)

  @@unique([userId, devotionalId])
  @@map("devotional_logs")
}

// ─────────────────────────────────────────────
// GRUPOS / CÉLULAS (12 pessoas)
// ─────────────────────────────────────────────
model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  maxMembers  Int      @default(12)
  progress    Float    @default(0)  // 0-100 progresso coletivo
  isPrivate   Boolean  @default(false)
  coverUrl    String?
  link        String?  // link externo (WhatsApp, Telegram, etc.)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     GroupMember[]
  invites     GroupInvite[]
  prayers     Prayer[]

  @@map("groups")
}

model GroupMember {
  id        String      @id @default(cuid())
  groupId   String
  group     Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      GroupRole   @default(MEMBER)
  joinedAt  DateTime    @default(now())

  @@unique([groupId, userId])
  @@map("group_members")
}

enum GroupRole {
  LEADER
  MEMBER
}

model GroupInvite {
  id        String       @id @default(cuid())
  groupId   String
  group     Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User         @relation("InviteSender", fields: [senderId], references: [id])
  token     String       @unique @default(cuid())
  status    InviteStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime     @default(now())

  @@map("group_invites")
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

// ─────────────────────────────────────────────
// PEDIDOS DE ORAÇÃO
// ─────────────────────────────────────────────
model Prayer {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId     String?
  group       Group?        @relation(fields: [groupId], references: [id])
  title       String
  description String?
  testimony   String?
  status      PrayerStatus  @default(PENDING)
  isPublic    Boolean       @default(false)  // sempre falso por padrão — explícito na API
  prayedCount Int           @default(0)
  answeredAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("prayers")
}

enum PrayerStatus {
  PENDING
  ANSWERED
  CLOSED
}

// ─────────────────────────────────────────────
// FEED DE GRATIDÃO
// ─────────────────────────────────────────────
model GratitudePost {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  imageUrl  String?
  createdAt DateTime   @default(now())

  reactions Reaction[]

  @@map("gratitude_posts")
}

model Reaction {
  id        String       @id @default(cuid())
  postId    String
  post      GratitudePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ReactionType

  @@unique([postId, userId])
  @@map("reactions")
}

enum ReactionType {
  AMEN        // Amém
  GLORY       // Glória a Deus
}

enum JournalMood {
  GRATIDAO
  APRENDIZADO
  DESAFIO
  LOUVOR
  PAZ
  ADORACAO
  RENOVACAO
  ARREPENDIMENTO
}

// ─────────────────────────────────────────────
// FCM TOKENS (Push Notifications — Premium)
// ─────────────────────────────────────────────
model FcmToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("fcm_tokens")
}

// ─────────────────────────────────────────────
// PLANOS DE LEITURA BÍBLICA (Premium)
// ─────────────────────────────────────────────
model ReadingPlan {
  id        String            @id @default(cuid())
  name      String
  slug      String            @unique
  daysTotal Int
  isPremium Boolean           @default(true)
  entries   ReadingEntry[]
  progress  ReadingProgress[]

  @@map("reading_plans")
}

model ReadingEntry {
  id        String      @id @default(cuid())
  planId    String
  day       Int
  reference String
  title     String?
  plan      ReadingPlan @relation(fields: [planId], references: [id])

  @@map("reading_entries")
}

model ReadingProgress {
  id         String      @id @default(cuid())
  userId     String
  planId     String
  currentDay Int         @default(0)
  startedAt  DateTime    @default(now())
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan       ReadingPlan @relation(fields: [planId], references: [id])

  @@unique([userId, planId])
  @@map("reading_progress")
}

model JournalEntry {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  content      String
  mood         JournalMood
  devotionalId String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("journal_entries")
}

// ─────────────────────────────────────────────
// VERSÍCULOS MEMORIZADOS
// ─────────────────────────────────────────────
model MemorizedVerse {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verse       String
  reference   String
  completedAt DateTime @default(now())

  @@unique([userId, reference])
  @@map("memorized_verses")
}

// ─────────────────────────────────────────────
// RATE LIMITING
// ─────────────────────────────────────────────
model RateLimit {
  id      String   @id @default(cuid())
  key     String
  count   Int      @default(1)
  window  DateTime

  @@unique([key, window])
  @@index([window])
  @@map("rate_limits")
}

// ─────────────────────────────────────────────
// VERIFICAÇÃO DE EMAIL
// ─────────────────────────────────────────────
model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique @default(cuid())
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("email_verification_tokens")
}

// ─────────────────────────────────────────────
// RESET DE SENHA
// ─────────────────────────────────────────────
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique @default(cuid())
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────
// NOTIFICAÇÕES
// ─────────────────────────────────────────────
enum NotificationType {
  REACTION
  PRAYED
  STREAK_RISK
  DEVOTIONAL
  GROUP_JOIN
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}
