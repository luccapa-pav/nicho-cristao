{
  "framework": "nextjs",
  "buildCommand": "npx prisma db push --skip-generate --accept-data-loss && npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/audio",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/devotional",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/streak-risk",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/cron/weekly-summary",
      "schedule": "0 8 * * 1"
    }
  ]
}
